[sub_resource type="GDScript" id="GDScript_eynsv"]
script/source = "extends EnemyNPC

func _ready():
	var x = Globals.get_key_name(\"text_show\")
	talk1 = [
		\"Ribbit, ribbit.\\n(Sigh...)\",
		\"(My friend never listens to me.)\",
		\"(Whenever I talk, she skips through my words by pressing [\"+x+\"].)\",
		\"(That's right.......)\\n(Pressing [\"+x+\"].............)\"
	]
	talk_end = [
		\"Ribbit, ribbit.\\n(You, too, can harness this power.)\",
		\"(I'd really rather you didn't though.)\\nRibbit.\"
	]
	super._ready()
"

[sub_resource type="GDScript" id="GDScript_3ftn5"]
script/source = "extends EnemyNPC

func _ready():
	var f4 = Globals.get_key_name(\"fullscreen\")
	talk1 = [
		\"Ribbit, ribbit.\\n(I heard using \\\"\"+f4+\"\\\" can make you have a \\\"full screen\\\".)\",
		\"(But what does \\\"\"+f4+\"\\\" stand for?)\\n(\\\"Four frogs\\\"?)\",
		\"(I have never seen more than three frogs in this room...)\",
		\"(This is troubling, to say the least.)\\nRibbit.\"
	]
	talk_end = [
		\"Ribbit, ribbit.\\n(Have you seen a fourth frog around here?)\",
		\"(If you have, I don't want to know.)\",
		\"(My worldview has been shattered by the idea.)\\nRibbit.\"
	]
	super._ready()
"

[sub_resource type="GDScript" id="GDScript_i2srn"]
script/source = "extends EnemyNPC

var pink = false

func _ready():
	pink = Globals.get_flag(\"pink_spare\")
	if pink:
		talk_end[1] = \"(Maybe one day, you'll have to do it even if they aren't pink.)\"
		talk_count += 1
	super._ready()

func talk(act):
	if talk_count > 1 and act == \"threat\" and not pink:
		await $Textbox.show_text([
			\"(Really? Then I'll tell all my friends to tell their friends' friends...)\",
			\"(To throw out their yellow outlines and use pink ones instead.)\",
		])
		pink = true
		Globals.set_flag(\"pink_spare\", true)
		talk_end[1] = \"(Maybe one day, you'll have to do it even if they aren't pink.)\"
	else:
		await super.talk(act)
"

