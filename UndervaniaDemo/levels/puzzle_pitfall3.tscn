[sub_resource type="GDScript" id="GDScript_pdw71"]
script/source = "extends NPC

const text = [
	[
		\"i fell down a hole...\\nnow i cant get up...\",
		\"go on without me...\",
		\"wait, i can fly, can't i...\",
		\"oh well...\"
	]
]

func _ready():
	if Globals.get_enemy_flag(\"napstablook\") == null or Globals.get_flag(\"napstablook_pitfall\"):
		self.hide()

func talk(_act):
	await $Textbox.show_text(text[0])
	self.rotation = 0
	self.position.y -= 10
	self.z_index = 11
	var tween = get_tree().create_tween()
	tween.tween_property(self, \"position\", Vector2(self.position.x, 240), 2)
	await tween.finished
	self.hide()
	Globals.set_flag(\"napstablook_pitfall\", true)
"

