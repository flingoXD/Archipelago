[sub_resource type="GDScript" id="GDScript_gptjx"]
script/source = "extends NPC

var talk_count = 0

var strytax_talk = preload(\"res://sounds/strytax_talk.wav\")
var broadsword = preload(\"res://items/dusty_broadsword.tres\")

func _ready():
	$Textbox.set_talk_sound(strytax_talk)

func talk(act):
	match act:
		\"talk\":
			var player: Player = Globals.game_manager.find_child(\"Player\")
			if Globals.get_flag(\"secret_prog\", 0) > 2:
				await $Textbox.show_text([
					\"Go to the tomb in the west.\",
					\"I shall rest here a moment before I set off.\"
				])
				return
			elif player.take_item(broadsword):
				await $Textbox.show_text([
					\"You have my sword already?\",
					\"Yes, that is indeed mine. A great sword it was once.\",
					\"Now, it is but dull, and covered in the dust of... I do not wish to think about it.\",
					\"I must go sharpen it, and polish my armor, and prepare for what must be done.\",
					\"For there is one final matter for us to attend to.\",
					\"If you have the resolve, then mark well my words!\",
					\"Meet me at the far western edge of the Ruins, above the ancient grave.\",
					\"You must seek the hidden path.\"
				])
				Globals.set_flag(\"secret_prog\", 3)
				return
		\"cheer\":
			await $Textbox.show_text([
				\"That is very nice of you, thank you.\",
				\"But surely you must have something better to do?\"
			])
			return
		\"threat\":
			await $Textbox.show_text(\"What are they teaching kids these days...\")
			return
		_:
			return
	match talk_count:
		0:
			await $Textbox.show_text([
				\"Hello again, human.\",
				\"Did you happen to find my sword anywhere?\"
			])
		1:
			await $Textbox.show_text([
				\"You did not? Ah, what a shame.\",
				\"If you do find anything, come back here.\",
				\"I like to go up here on top of the Ruins and just relax.\",
				\"There is not much else for me to do nowadays.\"
			])
		2:
			await $Textbox.show_text([
				\"Such a view...\",
				\"Here we can see the lands beyond, past the walls of the city.\",
				\"A very festive place, filled with kindly people.\",
				\"I suppose I miss them very much.\",
				\"But I had to come here. I made that choice long ago.\"
			])
		_:
			await $Textbox.show_text(\"Get along now. You must have something more important to do.\")
	talk_count += 1
"

[sub_resource type="GDScript" id="GDScript_j7t18"]
script/source = "extends NPC

const text = [
	[
		\"so you've met this guy too?\",
		\"i like to catch up with him occasionally\",
		\"but take care with him\",
		\"he's a bit of an odd fellow\",
		#\"when he's fixed on something, nothing can dissuade him\",
		\"he's very nice though...\",
		\"we can sit around and feel like garbage together...\"
	],
	[
		\"oh no...\",
		\"i don't think you should follow him\",
		\"but if you do\",
		\"make sure you have something that can block attacks\",
		\"old ribbons and bandages won't help you\"
	]
]

func _ready():
	if not Globals.get_flag(\"napstablook_pitfall\"):
		self.hide()

func talk(_act):
	await $Textbox.show_text(text[1 if Globals.get_flag(\"secret_prog\", 0) > 2 else 0])
"

