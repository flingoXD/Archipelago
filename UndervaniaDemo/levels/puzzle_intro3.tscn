[sub_resource type="GDScript" id="GDScript_2j7pq"]
script/source = "extends Enemy

var gravity = 0

signal talked

const text = [
	\"Ribbit, ribbit.\",
	\"Croak, croak.\",
	\"Hop, hop.\",
	\"Meow.\"
]

func _ready():
	super._ready()
	$AnimatedSprite2D.play(\"left\")

func talk(_act):
	$Textbox.show_text(text[randi()%len(text)], 2)
	talked.emit()

func _physics_process(delta):
	if gravity > 0:
		self.velocity.x = 150
		self.velocity.y += gravity*delta
		move_and_slide()
"

