[sub_resource type="GDScript" id="GDScript_36apf"]
script/source = "extends EnemyNPC

var counter = false

func _process(_delta):
	if $Textbox.visible:
		play(\"forward\")
		flip_h = false
	else:
		play(\"default\")
		counter = not counter
		if counter:
			flip_h = not flip_h
"

