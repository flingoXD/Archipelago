[sub_resource type="GDScript" id="GDScript_sbjpb"]
script/source = "extends EnemyNPC

func talk(act):
	if Globals.get_flag(\"toy_knife_collect\"):
		await $Textbox.show_text(\"Polyethylene.\")
	else:
		await super.talk(act)
"

