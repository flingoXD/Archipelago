[sub_resource type="GDScript" id="GDScript_7esyi"]
script/source = "extends NPC

var allium_talk = preload(\"res://sounds/allium_talk.wav\")

var talk_count = 0

func talk(_act):
	$Textbox.set_talk_sound(allium_talk)
	match talk_count:
		0:
			await $Textbox.show_text([
				\"Ugh, who is it this time?\",
				\"Is this ideal world yours?\",
				\"Kinda boring ngl.\"
			])
		1:
			await $Textbox.show_text([
				\"Or maybe it belongs to that big goat lady?\",
				\"She went past here a little while ago.\"
			])
		2:
			await $Textbox.show_text([
				\"Even Elyssa over there doesn't know where we are.\",
				\"Where's an omnipresent alter ego of questionable morality when you need them...\",
			])
		3:
			self.scale = Vector2(1.15, 1.15)
			self.skew = PI/6
			await $Textbox.show_text(\"GODDAMMIT ELYSSA WHERE THE HELL ARE WE\") #credit to Declarune for the idea
			self.scale = Vector2(1, 1)
			self.skew = 0
		4:
			await $Textbox.show_text([
				\"I... look like who?\",
				\"'Kris'? Never heard of them.\",
				\"Though now that you mention it, I do look a bit different to usual...\",
				\"oh god don't tell me I've ended up in ANOTHER game\"
			])
		5:
			await $Textbox.show_text([
				\"The locals seem really hostile towards us for some reason.\",
				\"Something about me being human?\",
				\"Personally, I wouldn't call myself a particularly 'human' kind of person...\",
				\"But, you know, whatever floats their boat.\"
			])
		6:
			await $Textbox.show_text([
				\"I'm bored so I'm gonna just repeat my last line of dialogue.\",
				\"wait I'm an NPC aren't I\"
			])
		_:
			await $Textbox.show_text(\"wait I'm an NPC aren't I\")
	talk_count += 1
"

[sub_resource type="GDScript" id="GDScript_8t0f6"]
script/source = "extends Sprite2D

const SPEED = 6
const FREQ = 1

var osc_time = 0

func _process(delta):
	osc_time += delta
	self.offset = Vector2(0, sin(osc_time*PI*FREQ))*SPEED
"

