[sub_resource type="GDScript" id="GDScript_s5hem"]
script/source = "extends NPC

var talk_count = 0

var strytax_talk = preload(\"res://sounds/strytax_talk.wav\")

func _ready():
	$Textbox.set_talk_sound(strytax_talk)

func talk(act):
	if not Globals.get_flag(\"dalv_room1_platform\"):
		await $Textbox.show_text([
			\"Ah, you want me to lower the platform for you?\",
			\"I see you are somewhat... lesser in stature, than I.\"
		])
		await get_parent().lower_platform()
		await $Textbox.show_text(\"There, that should suffice.\")
		return
	match act:
		\"talk\":
			pass
		\"cheer\":
			await $Textbox.show_text([
				\"You are very nice to tell an old monster such things.\",
				\"Now go seek somebody more worth complimenting than myself.\"
			])
			return
		\"threat\":
			await $Textbox.show_text(\"I shall keep that in mind.\")
			return
		_:
			return
	match talk_count:
		0:
			await $Textbox.show_text([
				\"Greetings, human. Welcome to the Dark Ruins.\",
				\"Once these were the slums of the poor and the city's workers.\",
				\"Now, like everywhere else, it is near deserted.\"
			])
		1:
			await $Textbox.show_text([
				\"The only exceptions are the few monsters that never wanted to leave.\",
				\"Look where it got them. Dying in a forgotten corner of the world...\",
				\"And of course, there are civilised folk like myself. Heheh.\"
			])
		2:
			await $Textbox.show_text([
				\"Who am I? Just someone of no consequence.\",
				\"There are a few others. One quite nice individual left not long after I arrived.\",
				\"I believe one like you passed through briefly around the same time.\",
				\"Sadly, I never had the pleasure of their acquaintance.\",
				\"And of course, there is our gracious lady...\",
				\"Ah, but few know about that. They are young and have their lives ahead of them.\"
			])
		_:
			await $Textbox.show_text(\"Get along now. Perhaps we shall meet again.\")
	talk_count += 1
"

