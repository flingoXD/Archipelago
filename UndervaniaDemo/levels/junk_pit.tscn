[sub_resource type="GDScript" id="GDScript_y3r4r"]
script/source = "extends Sprite2D

var shaking = false
var shake_intensity = 0

func _process(delta):
	if shaking:
		shake_intensity += delta
		self.offset = Vector2(
			randf_range(-shake_intensity, shake_intensity),
			randf_range(-shake_intensity, shake_intensity)
		)
	else:
		self.offset = Vector2.ZERO
"
