[sub_resource type="GDScript" id="GDScript_c3hpt"]
script/source = "extends NPC

const text = [
	[
		\"WHOA there pardner! Who said you could push me around?\"
	],
	[
		\"HMM? So you're ASKIN' me to move over?\",
		\"Okay, just for you, pumpkin.\"
	],
	[
		\"HMM? You want me to move some more?\",
		\"Alrighty, how's this?\"
	],
	[
		\"HMM? That was the wrong direction?\",
		\"Okay, think I got it.\"
	],
	[
		\"Can I go back yet? This spot's dull.\"
	],
	[
		\"HMM? You wanted me to STAY there?\",
		\"You're givin' me a real workout.\"
	],
	[
		\"You happy now?\"
	]
]

var walked_into = false
var line = 1
var locked = false

func _ready():
	talkable = false

func _process(_delta):
	if walked_into:
		return
	for body in $Area2D.get_overlapping_bodies():
		if body is Player:
			body.pause()
			walked_into = true
			await $Textbox.show_text(text[0])
			await get_tree().create_timer(0.5).timeout
			body.unpause()
			talkable = true

func talk(act):
	match act:
		\"cheer\":
			await $Textbox.show_text(\"Glad to hear it, sweet.\")
		\"talk\":
			await $Textbox.show_text(text[line])
			var tween = get_tree().create_tween()
			match line:
				1:
					tween.tween_property(self, \"position\", Vector2(250, 175), 0.5)
				2:
					tween.tween_property(self, \"position\", Vector2(250, 215), 1)
				3:
					tween.tween_property(self, \"position\", Vector2(250, 175), 1)
					tween.tween_property(self, \"position\", Vector2(330, 175), 2)
				5:
					tween.tween_property(self, \"position\", Vector2(330, 175), 0.5)
				_:
					tween.kill()
					return
			await tween.finished
			if line in [3, 5]:
				$AudioStreamPlayer.play()
				locked = true
			line += 1
"

