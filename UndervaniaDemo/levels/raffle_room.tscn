[sub_resource type="GDScript" id="GDScript_fn5y8"]
script/source = "extends NPC

var not_punchcard = preload(\"res://items/not_punchcard.tres\")

const text = [
	[
		\"Ribbit, ribbit.\\n(Hello, little human.)\",
		\"(You have come here at just the right time.)\",
		\"(We are organising a raffle for the other monsters in the Ruins.)\",
		\"(All earnings are donated to the RSPCM.)\",
		\"(Would you like to buy a ticket too?)\",
		\"(It only costs 10G.)\\nRibbit.\"
	],
	[
		\"Ribbit, ribbit.\\n(Thank you for your contribution!)\",
		\"(Don't forget to come back later to see if you've won anything.)\\nRibbit.\"
	],
	[
		\"Ribbit, ribbit.\\n(It seems you don't have enough gold for that!)\",
		\"(Come back when you're a little, um, richer.)\\nRibbit.\"
	],
	[
		\"Ribbit, ribbit.\\n(I'm sorry, human, you've come too late.)\",
		\"(The raffle's already over.)\\nRibbit.\"
	],
	[
		\"Ribbit, ribbit.\\n(Hello again, human!)\",
		\"(Let's see what your number is...)\",
		\"(Ah, you've won 100G! One of the biggest prizes.)\",
		\"(I hope you spend your winnings wisely.)\\nRibbit.\"
	],
	[
		\"(I hope you spend your winnings wisely.)\\nRibbit.\"
	]
]

func talk(_act):
	var player = Globals.game_manager.find_child(\"Player\")
	if Globals.get_enemy_flag(\"toriel\") != null:
		if not Globals.get_flag(\"raffle_contributed\"):
			await $Textbox.show_text(text[3])
		elif Globals.get_flag(\"raffle_redeemed\"):
			await $Textbox.show_text(text[5])
		else:
			# player.earn_gold(100)
			Globals.game_manager.ap_check_location(\"Raffle Ticket Rewards\")
			await $Textbox.show_text(text[4])
			# Globals.set_flag(\"raffle_redeemed\", true)
	elif not Globals.get_flag(\"raffle_encountered\"):
		Globals.set_flag(\"raffle_encountered\", true)
		await $Textbox.show_text(text[0])
	elif Globals.get_flag(\"raffle_contributed\"):
		await $Textbox.show_text(text[1])
	elif player.gold < 10:
		await $Textbox.show_text(text[2])
	elif Globals.game_manager.ap_check_location(not_punchcard.item_id):
		player.spend_gold(10)
		# Globals.set_flag(\"raffle_contributed\", true)
		await $Textbox.show_text(text[1])
	else:
		await $Textbox.show_text(\"(I don't think you have room to carry that.)\\nRibbit.\")
"

