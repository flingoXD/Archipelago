[sub_resource type="GDScript" id="GDScript_5akm3"]
script/source = "extends NPC

var talk_count = 0
var leavable = false
var toriel_bed = false

func _ready():
	if Globals.get_flag(\"toriel_bed\"):
		talk_count = 1
		toriel_bed = true

func talk(act):
	match talk_count:
		0:
			await $Textbox.show_text([
				\"Hello there, little one!\",
				\"The pie has not cooled down yet.\",
				\"Perhaps you should take a nap.\"
			])
		1:
			await $Textbox.show_text([
				\"Up already, I see?\" if toriel_bed else \"You'd rather stay up and chat with me, then?\",
				\"Um, I want you to know how glad I am to have someone here.\",
				\"There are so many old books I want to share.\",
				\"I want to show you my favorite bug-hunting spot.\",
				\"I've also prepared a curriculum for your education.\",
				\"This may come as a surprise to you, but I have always wanted to be a teacher.\",
				\"...actually, perhaps that isn't very surprising.\",
				\"STILL.\",
				\"I am glad to have you living here.\"
			])
		2:
			if act == \"cheer\":
				await $Textbox.show_text(\"Did you want to hear about this book I am reading?\")
			else:
				await $Textbox.show_text([
					\"What? This... this IS your home now.\",
					\"Um... did you want to hear about this book I am reading?\"
				])
			await $Textbox.show_text([
				\"It is called \\\"72 Uses for Snails.\\\"\",
				\"How about it?\"
			])
		_:
			if act == \"cheer\" or not leavable:
				await $Textbox.show_text(\"Here is an exciting snail fact.\" if act == \"cheer\" else \"Um... how about an exciting snail fact?\")
				await $Textbox.show_text([
					\"Did you know that snails have a chainsaw-like tongue called a redula?\",
					\"Did you know that snails sometimes flip their digestive systems as they mature?\",
					\"Did you know that snails make terrible shoelaces?\",
					[\"Did you know that snails. Talk. Really. Slowly?\", \"Just kidding, snails don't talk.\"],
					[\"Did you know that snails taste really good in pies?\", \"Um... not the pie I'm making for you. That is cinnamon and butterscotch.\"]
				].pick_random())
				await $Textbox.show_text(\"Interesting.\")
				leavable = true
			else:
				await $Textbox.show_text(\"...I have to do something. Stay here.\")
				await get_parent().toriel_leave()
	talk_count += 1
"

