enemy_id = "strytax"
talk1 = Array[String](["So apparently everyone else knew about the barrier all along.", "It is a great bubble around the Underground, blocking all sides.", "Even Toriel assumed I must have known, and that I was just... a \"loony\".", "Which, I suppose I was. Heheh.", "We have been talking here for a while now.", "We used to be friends, I think.", "I was much younger, and of course she never grows old...", "Ah, but Toriel was good friends with all of monsterkind, back then.", "The rest of the Underground lost a bright light the day she returned to the Ruins.", "We are lucky here to have her."])
talk_end = Array[String](["But I shall not bore you with my reminiscences any longer.", "Go out, leave the Ruins.", "Do what you must do."])
cheer = Array[String](["I wish you good fortune on your quest.", "Now grant me some solitude."])
metadata/_custom_type_script = "uid://60v7rjl1crdr"

