[sub_resource type="GDScript" id="GDScript_rp2wh"]
script/source = "extends NPC

var strytax_talk = preload(\"res://sounds/strytax_talk.wav\")

var talk_count = 0

const text = [
	[
		\"For me, now, it is time to diminish, and become the old Strytax you first met.\",
		\"My appearance was not entirely a facade, you know.\", #I wanted to put a cedilla but it looks stupid
		\"I was once a lot like that, and I want to find that part of me again.\"
	],
	[
		\"And to think that if you hadn't entered the Dark Ruins, we never would have met.\",
		\"Now I see this was always your story, and I merely a side character to it.\",
		\"I hope I have played my part well, and have not been too uninteresting, or demanded too much attention.\",
		\"Did I pass the test?\"
	],
	\"Did I pass the test?\"
]

func _ready():
	$Textbox.set_talk_sound(strytax_talk)

func talk(_act):
	if not Globals.get_flag(\"strytax_spare_amulet\"):
		var received = Globals.game_manager.find_child(\"Player\").add_item(get_parent().shadow_amulet)
		await $Textbox.show_text(get_parent().secret_text[3 if received else 4])
		Globals.set_flag(\"strytax_spare_amulet\", received)
		return
	await $Textbox.show_text(text[min(talk_count, 2)])
	talk_count += 1
"

