[sub_resource type="GDScript" id="GDScript_u3hhq"]
script/source = "extends Sprite2D

func run_animation():
	self.position = Vector2(6, -11)
	self.offset = Vector2.ZERO
	self.modulate.a = 1
	self.rotation = 0
	self.show()
	var tween = get_tree().create_tween().set_parallel()
	tween.tween_property(self, \"position\", self.position+Vector2(20, -20), 1)
	tween.tween_property(self, \"rotation\", 2*PI, 1)
	tween.tween_property(self, \"modulate\", Color(self.modulate, 0), 1)
	tween.tween_property(self, \"offset\", Vector2(4, 4), 1)
	tween.set_parallel(false)
	tween.tween_callback(self.hide)
"

