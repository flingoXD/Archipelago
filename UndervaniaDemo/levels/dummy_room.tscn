[sub_resource type="GDScript" id="GDScript_e4by0"]
script/source = "extends NPC

var first = true

func talk(_act):
	$Timer.paused = true
	$Textbox.position.x = 70
	if first:
		first = false
		await $Textbox.show_text([
			\"Do you need some ideas for conversation topics?\",
			\"Well, I often start with a simple \\\"how do you do...\\\"\",
			\"You could ask it about its favorite books...\",
			\"Jokes can be useful for \\\"breaking the ice\\\".\",
			\"Listen to this one...\\nWhat did the skeleton use to tile his roof with?\",
			\"He tiled it with SHIN-gles!\",
			\"...well I thought it was amusing.\"
		])
	else:
		await $Textbox.show_text([
			\"Practice talking to the dummy.\",
			\"You can say anything...\\nThe dummy will not be bothered.\",
		])
	$Timer.paused = false
"

