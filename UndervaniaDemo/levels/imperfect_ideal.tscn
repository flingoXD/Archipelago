[sub_resource type="GDScript" id="GDScript_vv73l"]
script/source = "extends NPC

var talk_count = 0
var cheer_count = 0
var speedrun = false
var dev_time = 528000000

func talk(act):
	var speedrun_time = Globals.get_flag(\"speedrun_time\")
	if speedrun_time and speedrun_time < dev_time and not speedrun:
		speedrun = true
		await $Textbox.show_text([
			\"Congratulations!\",
			\"You completed the game in \"+Time.get_time_string_from_unix_time(floor(speedrun_time*0.000001)).substr(4)+\".\",
			\"That's less than my own best time so far of \"+Time.get_time_string_from_unix_time(floor(dev_time*0.000001)).substr(4)+\"!\",
			\"Although I'm not much of a speedrunner so it's probably pretty easy to beat.\"
		])
		return
	match act:
		\"threat\":
			self.play(\"sad\")
			await $Textbox.show_text(\"......\")
			self.play(\"silly\")
			$MysteryGo.play()
			var tween = get_tree().create_tween()
			tween.tween_property(self, \"modulate\", Color.TRANSPARENT, 1)
			tween.tween_callback(self.hide)
			talkable = false
		\"cheer\":
			match cheer_count:
				0:
					await $Textbox.show_text([
						\"I'm glad you liked my little game!\",
						\"It took quite a while to make.\",
						\"And remember, this is only the beginning.\",
						\"If people like this, I might keep going and make all the rest of Undertale and Undertale Yellow!\"
					])
				1:
					await $Textbox.show_text([
						\"I've kinda started to plan out the rest of the game, very vaguely.\",
						\"It'll be mostly as you'd expect in terms of layout, just a bit less linear.\",
						\"I'm also gonna expand New Home into a bigger area and add a few new minor areas myself.\",
						\"You can see the blocked-off entrance to one of them below the Dark Caves.\"
					])
				2:
					await $Textbox.show_text([
						\"There'll be lots more movement abilities and ACTs, too.\",
						\"You can expect all the usual abilities like wall jump and dash, plus some new ones.\",
						\"Perhaps even some sort of offensive ACTs, which would alter enemies' behaviour and be useful outside of pacifist.\",
						\"The ACTs probably won't be as concentrated as they are in the Ruins, though.\",
						\"I needed to get the first few out near the start, including the crucial Talk and Check ACTs.\"
					])
					if not Globals.has_ability(\"check\"):
						await $Textbox.show_text([
							\"Wait, you didn't find Check, did you?\",
							\"Better get looking!\"
						])
				3:
					await $Textbox.show_text([
						\"I still haven't decided exactly how soul modes are gonna work.\",
						\"My current thought is that after each major boss, you'll get their soul mode and be able to use it elsewhere.\",
						\"They'll each have special abilities and drawbacks, kind of like crests in Silksong I guess.\",
						\"I didn't need to make them for this though, since you don't encounter them until the Papyrus fight.\"
					])
					if Globals.get_flag(\"secret_sans\"):
						await $Textbox.show_text([
							\"I see you've found the hidden Sans encounter, though...\",
							\"Yeah I did have to make a barebones implementation of the blue soul mode for that.\",
							\"Can't really make it give you gravity since you already have it.\",
							\"Instead, I made it disable your movement abilities.\",
							\"The plus side will probably be something that makes it more effective in combat, idk.\"
						])
				4:
					await $Textbox.show_text([
						\"But yeah, keep looking around.\",
						\"I put lots of secrets in, so there may well be something you missed.\",
						\"Even if it's just slightly different variants of Flowey's dialogue...\"
					])
				_:
					await $Textbox.show_text(\"Thanks for playing!\")
			cheer_count += 1
		\"talk\":
			match talk_count:
				0:
					await $Textbox.show_text([
						\"Hi! I'm theidealist, the creator of this little fangame.\",
						\"So this is the end of the demo for now.\",
						\"Why do I look like this? Well uhhhhh...\"
					])
					self.play(\"e\")
					await $Textbox.show_text(\"I'm not very good at art lol I just took most of the assets from Undertale\", 0.1)
				1:
					await $Textbox.show_text([
						\"Through that door over there is a little hub where you can fight bosses again if you like.\",
						\"You can use it to practice them, or try out different routes and interactions without consequences.\",
						\"Or, you could just reset and play the whole game again, experiencing them the intended way.\"
					])
				2:
					await $Textbox.show_text([
						\"I hope you also enjoyed the soundtrack - it's my specialty.\",
						\"It's mainly arrangements of Undertale music in my signature orchestral style.\"
					])
					self.play(\"music\")
					await $Textbox.show_text(\"There are a few original tracks in there too though.\")
					if Globals.get_persistent_flag(\"volume_music\", 1) == 0:
						self.play(\"e\")
						await get_tree().create_timer(1).timeout
						await $Textbox.show_text([
							\"Not that you'd know anything about them...\",
							\"Why? Why did you do it?\",
							\"Why did you turn off the music?\",
							\"I wouldn't have made this game if not for the opportunity to write lots of music for it.\",
							\"So why did you tear down what I'm most proud of?\"
						])
						await get_tree().create_timer(3).timeout
					self.play(\"default\")
					await $Textbox.show_text(\"When this comes out, I'll post the whole soundtrack on Youtube as well, so you can listen to it separately.\")
					self.play(\"silly\")
					await $Textbox.show_text(\"Or maybe I already have...\")
					self.play(\"default\")
				_:
					var napstablook = Globals.get_enemy_flag(\"napstablook\") != null
					var decibat = Globals.get_enemy_flag(\"decibat\") != null
					var toriel = Globals.get_enemy_flag(\"toriel\") != null
					var micro_froggit = Globals.get_enemy_flag(\"micro_froggit\") != null
					var strytax = Globals.get_enemy_flag(\"strytax\") != null
					var boss_count = (1 if napstablook else 0)+(1 if decibat else 0)+(1 if toriel else 0)+(1 if micro_froggit else 0)+(1 if strytax else 0)
					if boss_count >= 5:
						await $Textbox.show_text([
							\"You've beaten every boss in the demo!\",
							\"Now try beating them in different ways.\",
							\"Most of them can be beaten in two or three ways by killing or sparing them.\"
						])
					else:
						await $Textbox.show_text([
							\"So far, you've found and beaten \"+str(boss_count)+\" of the 5 bosses in this demo.\",
							\"You've still got \"+str(5-boss_count)+\" that you haven't found yet.\"
						])
						if not napstablook:
							await $Textbox.show_text([
								\"One of them lies fairly early on in the Ruins.\",
								\"It's completely optional but you can't get past it without a certain ACT.\"
							])
						if not decibat:
							await $Textbox.show_text([
								\"One of them is at the bottom of the Dark Ruins.\",
								\"I'm pretty sure it's impossible to skip though, so I don't know how you got here.\",
								\"Did you manage to skip it with a damage boost? I tried for ages but couldn't pull it off.\",
								\"Whichever way you did it, I'm very impressed.\"
							])
						if not toriel:
							await $Textbox.show_text([
								\"One of them lies at the end of the Ruins.\",
								\"But I'm pretty certain you can't get here without having just beaten it???\"
							])
						if not micro_froggit:
							await $Textbox.show_text([
								\"One of them lies in the Dark Caves.\",
								\"To get to it, you have to hit certain spots in the Dark Ruins in order.\"
							])
						if not strytax:
							await $Textbox.show_text([
								\"The last one is a secret, completely original to this game!\",
								\"I don't really want to give you any hints about how to get to it...\"
							])
							match Globals.get_flag(\"secret_prog\", 0):
								0:
									await $Textbox.show_text([
										\"Wait a minute... how did you get here without even meeting him once??\",
										\"I thought the first encounter was mandatory.\"
									])
								1:
									await $Textbox.show_text([
										\"But you should probably go down and check the rooms around Decibat's arena again.\",
										\"You might have missed something there.\"
									])
								2:
									await $Textbox.show_text([
										\"But you should probably explore a bit more.\",
										\"Do you remember where the old bug said to find him?\"\\
											if Globals.get_flag(\"dusty_broadsword_collect\")\\
											else \"Have you visited the Dark Caves yet?\"
									])
								3:
									await $Textbox.show_text([
										\"But I'd suggest you go back to the very first room, where the game began.\",
										\"You might find something there.\"
									])
			talk_count += 1
	if self.animation != \"silly\":
		self.play(\"default\")
"

