[sub_resource type="GDScript" id="GDScript_4cvvg"]
script/source = "extends Sprite2D

var aggro_texture = preload(\"res://sprites/aggro_star.png\")
var pink_texture = preload(\"res://sprites/spare_star_but_pink.png\")

func _ready():
	var tween = get_tree().create_tween().set_parallel()
	tween.tween_property(self, \"offset\", Vector2(0, -10), 1)
	tween.tween_property(self, \"modulate\", Color.TRANSPARENT, 1)
	await tween.finished
	self.queue_free()
"

