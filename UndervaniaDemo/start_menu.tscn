[sub_resource type="GDScript" id="GDScript_acoh7"]
script/source = "extends NPC

var toriel_talk = preload(\"res://sounds/toriel_talk.wav\")

var hd_remaster = Globals.get_persistent_flag(\"silly_shader\") == \"hd_remaster\"

func _ready():
	if hd_remaster:
		self.play(\"hd_remaster\")
		self.scale = Vector2(0.5, 0.5)
		$Textbox.position *= 2
		$Textbox.scale *= 2

func talk(_act):
	$Textbox.set_talk_sound(toriel_talk)
	await $Textbox.show_text([
		\"Be careful out there, my child.\",
		\"I wish you good luck.\"
	])
"

[sub_resource type="GDScript" id="GDScript_w8jvl"]
script/source = "extends NPC

var strytax_talk = preload(\"res://sounds/strytax_talk.wav\")

const text = [
	[
		\"Ah, hello again, human... I am so tired...\",
		\"All the ambitions of my whole life, simply gone.\",
		\"I do not know what to do with myself now.\",
		\"Perhaps I shall take up knitting.\"
	],
	[
		\"You have done well, child of man.\"
	]
]
var talked_to = false

func talk(_act):
	$Textbox.set_talk_sound(strytax_talk)
	await $Textbox.show_text(text[1 if talked_to else 0])
	talked_to = true
"

