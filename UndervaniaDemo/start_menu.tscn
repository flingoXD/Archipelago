[sub_resource type="GDScript" id="GDScript_6p4e4"]
script/source = "extends NPC

var flowey_talk = preload(\"res://sounds/flowey_talk.wav\")

func talk(_act):
	$Textbox.set_talk_sound(flowey_talk)
	await $Textbox.show_text(\"Don't you have anything better to do?\")
"

[sub_resource type="GDScript" id="GDScript_jxkec"]
script/source = "extends NPC

const text = [
	[
		\"oh... hi...\",
		\"i put this hat back on for some\\nreason\",
		\"i can keep it on if you like...\",
		\"or not...\"
	],
	[
		\"...\"
	]
]
var talked_to = false

func talk(_act):
	await $Textbox.show_text(text[1 if talked_to else 0])
	talked_to = true
"

